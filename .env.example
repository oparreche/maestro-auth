# Copie para .env e preencha. NUNCA versione o .env com segredos reais.

# Porta do serviço
PORT=8080

# URL pública deste serviço (sem barra no fim). Ex.: https://auth.seudominio.com
# É com base nela que montamos o callback do OAuth.
PUBLIC_URL=https://auth.seudominio.com

# Segredo para assinar os tokens (gere algo longo e aleatório):
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# OAuth GitHub — crie em: GitHub > Settings > Developer settings > OAuth Apps
#   Authorization callback URL = <PUBLIC_URL>/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# OAuth Bitbucket (opcional) — crie em: Bitbucket > Workspace settings >
#   OAuth consumers. Callback URL = <PUBLIC_URL>/auth/bitbucket/callback
#   Permissões: Account (read) e Email (read). Marque "This is a private consumer".
BITBUCKET_CLIENT_ID=
BITBUCKET_CLIENT_SECRET=

# Quem entra já como GESTOR (logins do GitHub, separados por vírgula).
# O primeiro gestor sai daqui (resolve o ovo-galinha de "só gestor gerencia usuários").
GESTOR_LOGINS=oparreche

# (Opcional) logins pré-aprovados como DEV. Quem não estiver em lista nenhuma
# entra como "pending" (sem acesso) até um gestor aprovar.
DEV_LOGINS=

# Validade do token
TOKEN_TTL=12h

# Pasta de dados (store.json). Em deploy, aponte para um volume persistente.
DATA_DIR=./data
